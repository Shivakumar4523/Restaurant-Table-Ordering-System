# Docker Compose ports
FRONTEND_PORT=3000
BACKEND_PORT=5000

# Public frontend values. These are baked into the Vite client bundle at image build time.
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Backend values
PORT=5000
MONGO_URI=mongodb://mongodb:27017/royal-spice
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000
GST_PERCENTAGE=5
RATE_LIMIT_MAX=5000
RATE_LIMIT_WINDOW_MS=900000

# Razorpay secret values stay backend-only.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=replace-with-your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-your-webhook-secret

# Restaurant integrations
WHATSAPP_PHONE=919999999999
RESTAURANT_LAT=28.6139
RESTAURANT_LNG=77.2090
