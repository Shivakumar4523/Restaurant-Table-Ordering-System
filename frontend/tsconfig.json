{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src/main.tsx", "src/RootApp.tsx", "src/lib/**/*.ts", "src/context/**/*.tsx", "src/routes/**/*.tsx", "src/components/**/*.tsx", "src/pages/**/*.tsx", "vite.config.ts"],
  "exclude": ["node_modules"]
}
